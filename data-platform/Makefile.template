#################### Lake Formation ####################

set-up-lake-formation-admin-role:
	@CALLER_ARN=$$(aws sts get-caller-identity --query Arn --output text --region ${AWS_PRIMARY_REGION} | \
		sed 's|arn:aws:sts:|arn:aws:iam:|;s|:assumed-role/\([^/]*\)/.*|:role/\1|'); \
	aws lakeformation put-data-lake-settings \
		--cli-input-json "{\"DataLakeSettings\": {\"DataLakeAdmins\": [{\"DataLakePrincipalIdentifier\": \"arn:aws:iam::${AWS_ACCOUNT_ID}:role/${ADMIN_ROLE}\"}, {\"DataLakePrincipalIdentifier\": \"arn:aws:iam::${AWS_ACCOUNT_ID}:user/datapipeline\"}, {\"DataLakePrincipalIdentifier\": \"arn:aws:iam::${AWS_ACCOUNT_ID}:role/${APP_NAME}-${ENV_NAME}-quicksight-service-role\"}, {\"DataLakePrincipalIdentifier\": \"$$CALLER_ARN\"}]}}" \
		--region "${AWS_PRIMARY_REGION}"

set-up-redshift-lf-readonly-admin:
	@echo "Adding AWSServiceRoleForRedshift as Lake Formation read-only admin"
	@CURRENT=$$(aws lakeformation get-data-lake-settings --region ${AWS_PRIMARY_REGION} --output json 2>/dev/null); \
	ADMINS=$$(echo "$$CURRENT" | python3 -c "import json,sys;d=json.load(sys.stdin);print(json.dumps(d['DataLakeSettings']['DataLakeAdmins']))"); \
	aws lakeformation put-data-lake-settings \
		--data-lake-settings "{\"DataLakeAdmins\": $$ADMINS, \"ReadOnlyAdmins\": [{\"DataLakePrincipalIdentifier\": \"arn:aws:iam::${AWS_ACCOUNT_ID}:role/aws-service-role/redshift.amazonaws.com/AWSServiceRoleForRedshift\"}]}" \
		--region "${AWS_PRIMARY_REGION}"
	@echo "Finished adding Redshift service role as Lake Formation read-only admin"
		
create-glue-s3tables-catalog:
	# Idempotent — AlreadyExistsException is expected on re-runs
	aws glue create-catalog \
		--cli-input-json '{"Name": "s3tablescatalog", "CatalogInput": { "FederatedCatalog": { "Identifier": "arn:aws:s3tables:${AWS_PRIMARY_REGION}:${AWS_ACCOUNT_ID}:bucket/*", "ConnectionName": "aws:s3tables" }, "CreateDatabaseDefaultPermissions": [], "CreateTableDefaultPermissions": [] } }' \
		--region "${AWS_PRIMARY_REGION}" || true

register-s3table-catalog-with-lake-formation:
	aws lakeformation register-resource \
        --resource-arn "arn:aws:s3tables:${AWS_PRIMARY_REGION}:${AWS_ACCOUNT_ID}:bucket/*" \
        --role-arn "arn:aws:iam::${AWS_ACCOUNT_ID}:role/${APP_NAME}-${ENV_NAME}-lakeformation-service-role" \
        --with-federation \
        --region "${AWS_PRIMARY_REGION}" || true

grant-default-database-permissions:
	@echo "Checking default database and granting Lake Formation permissions"
	@if aws glue get-database --name default >/dev/null 2>&1; then \
		echo "Default database exists. Granting Lake Formation permissions..."; \
		aws lakeformation grant-permissions \
			--principal DataLakePrincipalIdentifier="arn:aws:iam::${AWS_ACCOUNT_ID}:role/${ADMIN_ROLE}" \
			--resource '{"Database": {"Name": "default"}}' \
			--permissions "DROP" \
			--region $(AWS_PRIMARY_REGION); \
		aws lakeformation grant-permissions \
			--principal DataLakePrincipalIdentifier="arn:aws:iam::${AWS_ACCOUNT_ID}:user/datapipeline" \
			--resource '{"Database": {"Name": "default"}}' \
			--permissions "DROP" \
			--region $(AWS_PRIMARY_REGION); \
		echo "Successfully granted Lake Formation permissions for default database"; \
	else \
		echo "Default database does not exist"; \
	fi

