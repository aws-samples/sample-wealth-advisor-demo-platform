wait-datazone-stacks:
	@echo "Waiting for DataZone environment stacks to complete..."
	# Poll until no DataZone-* stacks are CREATE_IN_PROGRESS.
	# Uses consecutive-zero-count to handle child stacks that haven't been created yet
	# (parent stack finishes → brief gap → child stacks start).
	@ZERO_COUNT=0; \
	while true; do \
		IN_PROGRESS=$$(aws cloudformation list-stacks \
			--stack-status-filter CREATE_IN_PROGRESS \
			--query "StackSummaries[?starts_with(StackName, 'DataZone-')].StackName" \
			--output text --region $(AWS_PRIMARY_REGION)); \
		if [ -z "$$IN_PROGRESS" ] || [ "$$IN_PROGRESS" = "None" ]; then \
			ZERO_COUNT=$$((ZERO_COUNT + 1)); \
			echo "No in-progress DataZone stacks (check $$ZERO_COUNT/3)"; \
			if [ $$ZERO_COUNT -ge 3 ]; then break; fi; \
		else \
			ZERO_COUNT=0; \
			echo "Waiting for: $$IN_PROGRESS"; \
		fi; \
		sleep 30; \
	done
	@echo "All DataZone environment stacks are ready"

# Separate target so Make runs the wait a second time after the consumer project.
# GNU Make deduplicates prerequisites, so reusing wait-datazone-stacks would be a no-op.
wait-datazone-stacks-consumer:
	@echo "Waiting for DataZone environment stacks to complete (consumer)..."
	@ZERO_COUNT=0; \
	while true; do \
		IN_PROGRESS=$$(aws cloudformation list-stacks \
			--stack-status-filter CREATE_IN_PROGRESS \
			--query "StackSummaries[?starts_with(StackName, 'DataZone-')].StackName" \
			--output text --region $(AWS_PRIMARY_REGION)); \
		if [ -z "$$IN_PROGRESS" ] || [ "$$IN_PROGRESS" = "None" ]; then \
			ZERO_COUNT=$$((ZERO_COUNT + 1)); \
			echo "No in-progress DataZone stacks (check $$ZERO_COUNT/3)"; \
			if [ $$ZERO_COUNT -ge 3 ]; then break; fi; \
		else \
			ZERO_COUNT=0; \
			echo "Waiting for: $$IN_PROGRESS"; \
		fi; \
		sleep 30; \
	done
	@echo "All DataZone environment stacks are ready (consumer)"

