load-redshift-tables:
	@echo "Loading data into Redshift tables"
	@for table in $(REDSHIFT_TABLES); do \
		echo "Loading $$table..."; \
		aws redshift-data execute-statement \
			--workgroup-name "$(REDSHIFT_WORKGROUP)" \
			--database "dev" \
			--sql "TRUNCATE public.$$table; COPY public.$$table FROM 's3://$(DATA_BUCKET)/$$table.csv' IAM_ROLE '$(REDSHIFT_COPY_ROLE)' CSV IGNOREHEADER 1 TIMEFORMAT 'auto' REGION '$(AWS_PRIMARY_REGION)';" \
			--region "$(AWS_PRIMARY_REGION)"; \
	done
	@echo "Finished loading Redshift tables"

