PRODUCER_REDSHIFT_ENV_ID := $(shell aws ssm get-parameter --name /$(APP_NAME)/$(ENV_NAME)/sagemaker/producer/redshift-env-id --query "Parameter.Value" --output text --region $(AWS_PRIMARY_REGION) 2>/dev/null)
REDSHIFT_WORKGROUP := redshift-serverless-workgroup-$(PRODUCER_REDSHIFT_ENV_ID)

create-redshift-tables:
	@echo "Creating Redshift tables in workgroup $(REDSHIFT_WORKGROUP)"
	aws redshift-data execute-statement \
		--workgroup-name "$(REDSHIFT_WORKGROUP)" \
		--database "dev" \
		--sql "$(shell cat ddl-redshift/redshift-tables.sql)" \
		--region "$(AWS_PRIMARY_REGION)"
	@echo "Finished creating Redshift tables"

create-redshift-views-s3tables:
	@echo "Creating Redshift S3 table views in workgroup $(REDSHIFT_WORKGROUP)"
	aws redshift-data execute-statement \
		--workgroup-name "$(REDSHIFT_WORKGROUP)" \
		--database "dev" \
		--sql file://ddl-redshift/redshift-views-s3tables.sql \
		--region "$(AWS_PRIMARY_REGION)"
	@echo "Finished creating Redshift S3 table views"

create-quicksight-tables:
	@echo "Creating QuickSight snapshot tables from Redshift views"
	aws redshift-data execute-statement \
		--workgroup-name "$(REDSHIFT_WORKGROUP)" \
		--database "dev" \
		--sql "DROP TABLE IF EXISTS public.qs_advisor_dashboard_summary; CREATE TABLE public.qs_advisor_dashboard_summary AS SELECT * FROM public.advisor_dashboard_summary;" \
		--region "$(AWS_PRIMARY_REGION)"
	@echo "Finished creating QuickSight snapshot tables"

refresh-quicksight-tables:
	@echo "Refreshing QuickSight snapshot tables"
	aws redshift-data execute-statement \
		--workgroup-name "$(REDSHIFT_WORKGROUP)" \
		--database "dev" \
		--sql "TRUNCATE public.qs_advisor_dashboard_summary; INSERT INTO public.qs_advisor_dashboard_summary SELECT * FROM public.advisor_dashboard_summary;" \
		--region "$(AWS_PRIMARY_REGION)"
	@echo "Finished refreshing QuickSight snapshot tables"

RUM_DATA_DIR = data/rum
RUM_TABLES = rum_page_views rum_errors rum_performance

create-rum-tables:
	@echo "Creating RUM tables in Redshift"
	aws redshift-data execute-statement \
		--workgroup-name "$(REDSHIFT_WORKGROUP)" \
		--database "dev" \
		--sql "$$(cat ddl-redshift/redshift-rum-tables.sql)" \
		--region "$(AWS_PRIMARY_REGION)"
	@echo "Finished creating RUM tables"

upload-rum-data:
	@echo "Uploading RUM data to S3"
	@for table in $(RUM_TABLES); do \
		aws s3 cp $(RUM_DATA_DIR)/$$table.csv s3://$(DATA_BUCKET)/$$table.csv --region $(AWS_PRIMARY_REGION); \
	done
	@echo "Finished uploading RUM data"

load-rum-data: upload-rum-data
	@echo "Loading RUM data into Redshift"
	@for table in $(RUM_TABLES); do \
		echo "Loading $$table..."; \
		aws redshift-data execute-statement \
			--workgroup-name "$(REDSHIFT_WORKGROUP)" \
			--database "dev" \
			--sql "TRUNCATE public.$$table; COPY public.$$table FROM 's3://$(DATA_BUCKET)/$$table.csv' IAM_ROLE '$(REDSHIFT_COPY_ROLE)' CSV IGNOREHEADER 1 TIMEFORMAT 'auto' REGION '$(AWS_PRIMARY_REGION)';" \
			--region "$(AWS_PRIMARY_REGION)"; \
	done
	@echo "Finished loading RUM data"

create-rum-all: create-rum-tables load-rum-data

create-redshift-all: create-redshift-tables load-redshift-tables create-redshift-views-s3tables create-quicksight-tables

