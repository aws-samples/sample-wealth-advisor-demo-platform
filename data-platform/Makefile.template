deploy-redshift-ddl: create-redshift-tables load-redshift-tables create-redshift-views-s3tables create-quicksight-tables

grant-redshift-admin-access:
	@echo "Granting Redshift admin access"
	$(eval REDSHIFT_ADMIN_SECRET := $(shell aws secretsmanager list-secrets \
		--filter Key=name,Values=redshift!redshift-serverless-namespace \
		--region $(AWS_PRIMARY_REGION) \
		--query 'SecretList[?contains(Name, `admin`)].ARN | [0]' \
		--output text))
	@echo "Using secret: $(REDSHIFT_ADMIN_SECRET)"
	@echo "Using workgroup: $(REDSHIFT_WORKGROUP)"
	@run_sql() { \
		local sql="$$1"; \
		local id=$$(aws redshift-data execute-statement \
			--workgroup-name "$(REDSHIFT_WORKGROUP)" \
			--secret-arn "$(REDSHIFT_ADMIN_SECRET)" \
			--database "dev" \
			--sql "$$sql" \
			--region "$(AWS_PRIMARY_REGION)" \
			--query Id --output text); \
		echo "  Statement ID: $$id"; \
		while true; do \
			status=$$(aws redshift-data describe-statement --id "$$id" \
				--region "$(AWS_PRIMARY_REGION)" \
				--query Status --output text); \
			[ "$$status" = "FINISHED" ] && break; \
			[ "$$status" = "FAILED" ] && { \
				aws redshift-data describe-statement --id "$$id" \
					--region "$(AWS_PRIMARY_REGION)" \
					--query Error --output text; \
				return 1; \
			}; \
			sleep 2; \
		done; \
	}; \
	echo "Creating IAM role user..."; \
	run_sql 'CREATE USER "IAMR:$(ADMIN_ROLE)" PASSWORD DISABLE' || true; \
	echo "Creating IAM datapipeline user..."; \
	run_sql 'CREATE USER "IAM:datapipeline" PASSWORD DISABLE' || true; \
	echo "Granting access to IAM:datapipeline..."; \
	run_sql 'GRANT USAGE ON SCHEMA public TO "IAM:datapipeline"'; \
	run_sql 'GRANT SELECT ON ALL TABLES IN SCHEMA public TO "IAM:datapipeline"'; \
	run_sql 'ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO "IAM:datapipeline"'; \
	echo "Granting access to IAMR:$(ADMIN_ROLE)..."; \
	run_sql 'GRANT USAGE ON SCHEMA public TO "IAMR:$(ADMIN_ROLE)"'; \
	run_sql 'GRANT SELECT ON ALL TABLES IN SCHEMA public TO "IAMR:$(ADMIN_ROLE)"'; \
	run_sql 'ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO "IAMR:$(ADMIN_ROLE)"'
	@echo "Finished granting Redshift admin access"

