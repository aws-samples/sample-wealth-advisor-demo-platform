# ╔══════════════════════════════════════════════════════════════════════╗
# ║  THIS FILE IS THE SCHEMA FOR `pnpm nx setup`.                      ║
# ║  scripts/setup.mjs parses it to generate .env interactively.       ║
# ║                                                                     ║
# ║  CONVENTIONS:                                                       ║
# ║                                                                     ║
# ║  Sections:  # ─── Section Name ────────────────────────             ║
# ║    "Required:" sections  → always prompted                          ║
# ║    "Deployment:" sections → prompted only when deploying            ║
# ║    All other sections     → copied as-is, never prompted            ║
# ║                                                                     ║
# ║  Variables:                                                         ║
# ║    # @prompt Description of the variable                            ║
# ║    VAR_NAME=default-value     ← prompted, default shown in [...]    ║
# ║                                                                     ║
# ║    # @prompt Description                                            ║
# ║    VAR_NAME=<placeholder>     ← prompted, no default (must type)   ║
# ║                                                                     ║
# ║    # @prompt Description                                            ║
# ║    # VAR_NAME=value           ← optional; uncommented if answered  ║
# ║                                                                     ║
# ║    # @skip-if OTHER_VAR=value                                       ║
# ║    VAR_NAME=default           ← skipped entirely if condition met  ║
# ║                                                                     ║
# ║    # @ssm /{APP}/{ENV}/ssm/path                                     ║
# ║    VAR_NAME=<placeholder>     ← auto-populated from data-platform   ║
# ║                                                                     ║
# ║    # @ssm-prefix some-prefix-                                        ║
# ║    (prepends prefix to the fetched SSM value)                        ║
# ║                                                                     ║
# ║    # @post-run action-name                                           ║
# ║    VAR_NAME=value             ← runs named action after prompt      ║
# ║                                                                     ║
# ║    # VAR_NAME=value           ← no @prompt = passthrough, no ask   ║
# ║                                                                     ║
# ║  To add a new variable:                                             ║
# ║    1. Add it under the right section (or create a new one)          ║
# ║    2. Put `# @prompt Your description` on the line above            ║
# ║    3. That's it — setup.mjs will pick it up automatically           ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── Required: AWS ────────────────────────────────────────────────────
# @prompt AWS region where your Redshift cluster and infrastructure are deployed
AWS_REGION=us-west-2
# @prompt Your 12-digit AWS account ID where Redshift and infrastructure are deployed
AWS_ACCOUNT_ID=<your-aws-account-id>
# @prompt Use default credential chain instead of a named profile? Set true on EC2/Cloud9 where instance roles provide credentials (true/false)
USE_DEFAULT_AWS_CREDENTIALS=false
# @prompt AWS CLI profile name from ~/.aws/credentials — used for local API and CDK commands
# @skip-if USE_DEFAULT_AWS_CREDENTIALS=true
AWS_PROFILE=default

# ─── Required: Redshift ──────────────────────────────────────────────
# @ssm /{APP}/{ENV}/sagemaker/producer/redshift-env-id
# @ssm-prefix redshift-serverless-workgroup-
# @prompt Redshift Serverless workgroup name — the APIs connect here for all data queries
REDSHIFT_WORKGROUP=<your-redshift-workgroup>
# @prompt Redshift Serverless database name within the workgroup (data-platform default: "dev")
REDSHIFT_DATABASE=dev

# ─── Deployment: VPC / Networking ────────────────────────────────────
# Lambda functions need VPC access to reach Redshift. Find these in the VPC console.
# @ssm /{APP}/{ENV}/vpc_id
# @prompt VPC ID where Redshift Serverless is deployed (VPC console > Your VPCs)
REDSHIFT_VPC_ID=<vpc-xxxxxxxxxxxxxxxxx>
# @ssm /{APP}/{ENV}/vpc_private_subnet_ids
# @prompt Private subnet IDs with Redshift access, comma-separated (VPC console > Subnets)
PRIVATE_SUBNET_IDS=<subnet-xxx,subnet-yyy>
# @ssm /{APP}/{ENV}/sagemaker/producer/security-group
# @prompt Security group attached to Redshift — Lambdas get ingress rules added to it (VPC console > Security Groups)
REDSHIFT_SECURITY_GROUP_ID=<sg-xxxxxxxxxxxxxxxxx>
# @ssm /{APP}/{ENV}/vpc_private_route_table_id
# @prompt Route table for the private subnets — used to add VPC endpoint routes (VPC console > Route Tables)
PRIVATE_ROUTE_TABLE_ID=<rtb-xxxxxxxxxxxxxxxxx>

# ─── Deployment: Bastion Host ─────────────────────────────────────────
# Optional SSM bastion EC2 instance for tunneling to Redshift from your laptop.
# Only needed if Redshift is in a private subnet with no direct connectivity.
# @prompt Deploy an SSM bastion host for Redshift access? (true/false)
# DEPLOY_BASTION=false
# @prompt Availability zone for the bastion instance — must match one of your private subnets
# PRIVATE_SUBNET_AZ=<e.g. us-west-2b>

# ─── Deployment: AI / ML ─────────────────────────────────────────────
# @prompt Bedrock model ID for AI-generated client reports — must be enabled in your account's Bedrock console
REPORT_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# @prompt Tavily API key for web search in market insights — get one at https://tavily.com (leave blank to skip)
# TAVILY_API_KEY=<your-tavily-api-key>

# @prompt Bedrock model ID for market theme and portfolio theme generation
THEME_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ─── Advisor Chat Agent Models ────────────────────────────────────────
# @prompt Bedrock model ID for the advisor chat routing agent (intent classification + orchestration)
ROUTING_BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# @prompt Bedrock model ID for database and web search sub-agents
SUBAGENT_BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# @prompt Bedrock model ID for the stock data agent (market quotes + analysis)
STOCK_AGENT_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# @prompt Bedrock model ID for the voice gateway agent (Nova Sonic speech-to-speech)
VOICE_AGENT_BEDROCK_MODEL_ID=amazon.nova-2-sonic-v1:0

# ─── Deployment: Email ───────────────────────────────────────────────
# @prompt SES sender email for scheduled report delivery (leave blank to skip)
# @post-run verify-ses-identity
# SES_SENDER_EMAIL=<verified-ses-email>

# ─── Deployment: Neptune Graph ───────────────────────────────────────
# GRAPH_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ─── Deployment: Compliance Reporting ─────────────────────────────────
# @skip-if DEPLOY_BASTION=false
# @prompt Enable compliance reporting to sync inventory data to S3? (true/false)
# ENABLE_COMPLIANCE_REPORTING=false
# @skip-if ENABLE_COMPLIANCE_REPORTING=false
# @prompt S3 bucket pattern for compliance reporting — use {region} as placeholder
# COMPLIANCE_REPORTING_BUCKET=<bucket-pattern>

# ─── Optional: CDK Stage Name (default: sandbox) ─────────────────────
# STAGE_NAME=sandbox

# ─── Local Development Overrides ─────────────────────────────────────
# SSM tunnel: routes Redshift queries through localhost via bastion.
# Comment these out on EC2 instances with direct VPC peering to Redshift,
# otherwise engine.py connects to localhost instead of the serverless endpoint.
REDSHIFT_HOST=localhost
REDSHIFT_PORT=5439

# Local API URLs (uncomment for serve-local mode)
# VITE_API_URL=http://localhost:8000
# VITE_INTELLIGENCE_API_URL=http://localhost:8001
# VITE_REPORT_API_URL=http://localhost:8003
# VITE_GRAPH_SEARCH_API_URL=http://localhost:8005
# GRAPH_SEARCH_AGENT_URL=http://localhost:8084

# ─── Post-Deployment Values ──────────────────────────────────────────
# These are populated after `pnpm nx deploy @wealth-management-portal/infra`
# Find them in CloudFormation stack outputs or resources.
# NEPTUNE_GRAPH_ID=<from stack outputs or SSM: /wealth-management-portal/neptune-graph-id>
# REPORT_S3_BUCKET=<from stack outputs>
# CLIENT_SEARCH_AGENT_ARN=<from stack outputs>
CLIENT_SEARCH_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# ROUTING_AGENT_ARN=<from stack outputs>
# CLIENT_REPORT_AGENT_ARN=<from stack outputs>  # deprecated — use DATABASE_AGENT_ARN
# DATABASE_AGENT_ARN=<from stack outputs>
# MARKET_INSIGHTS_AGENT_ARN=<from stack outputs>
# KNOWLEDGE_BASE_AGENT_ARN=<from stack outputs>
# WEB_SEARCH_AGENT_ARN=<from stack outputs>

# ─── Integration Test Values (optional) ──────────────────────────────
# SCHEDULES_TABLE_NAME=<from stack resources>
# SCHEDULE_RESULTS_TABLE_NAME=<from stack resources>
# EXECUTOR_LAMBDA_ARN=<from stack resources>
# EVENTBRIDGE_ROLE_ARN=<from stack resources>
# REPORT_BUCKET_NAME=<from stack resources>
# TEST_S3_BUCKET=<from stack resources>
# SCHEDULER_GATEWAY_URL=<from gateway>
# EMAIL_SENDER_GATEWAY_URL=<from gateway>
