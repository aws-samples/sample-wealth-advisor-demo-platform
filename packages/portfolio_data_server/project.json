{
  "name": "wealth_management_portal.portfolio_data_server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "packages/portfolio_data_server/wealth_management_portal_portfolio_data_server",
  "release": {
    "version": {
      "versionActions": "@nxlv/python/src/release/version-actions"
    }
  },
  "tags": [],
  "metadata": {
    "generator": "py#project",
    "components": [
      {
        "generator": "py#lambda-function",
        "name": "portfolio-data-gateway"
      }
    ]
