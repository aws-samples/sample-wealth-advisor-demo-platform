{
  "name": "wealth_management_portal.graph_search_api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "packages/graph_search_api/wealth_management_portal_graph_search_api",
  "release": {
    "version": {
      "versionActions": "@nxlv/python/src/release/version-actions"
    }
  },
  "tags": [],
  "metadata": {
    "generator": "py#fast-api",
    "ports": [8005],
    "apiName": "graph_search_api",
    "apiType": "fast-api",
    "auth": "IAM"
  },
  "targets": {
    "add": {
      "executor": "@nxlv/python:add",
      "options": {}
    },
    "build": {
      "dependsOn": ["lint", "compile", "test", "bundle", "openapi"],
      "options": {
        "outputPath": "{workspaceRoot}/dist/packages/graph_search_api"
      }
    },
    "bundle": {
      "dependsOn": ["bundle-x86"]
    },
    "bundle-x86": {
      "cache": true,
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/graph_search_api/bundle-x86"],
      "options": {
        "commands": [
          "uv export --frozen --no-dev --no-editable --project packages/graph_search_api --package wealth_management_portal.graph_search_api -o dist/packages/graph_search_api/bundle-x86/requirements.txt",
          "uv pip install -n --no-deps --no-installer-metadata --no-compile-bytecode --python-platform x86_64-manylinux_2_28 --target dist/packages/graph_search_api/bundle-x86 -r dist/packages/graph_search_api/bundle-x86/requirements.txt"
        ],
        "parallel": false
      },
      "dependsOn": ["compile"]
    },
    "compile": {
      "executor": "@nxlv/python:build",
      "outputs": ["{workspaceRoot}/dist/packages/graph_search_api/build"],
      "options": {
        "outputPath": "{workspaceRoot}/dist/packages/graph_search_api/build",
        "publish": false,
        "lockedVersions": true,
        "bundleLocalDependencies": true
      },
      "cache": true
    },
    "format": {
      "executor": "@nxlv/python:ruff-format",
      "outputs": [],
      "options": {
        "filePatterns": ["wealth_management_portal_graph_search_api", "tests"]
      },
      "cache": true
    },
    "install": {
      "executor": "@nxlv/python:install",
      "options": {
        "silent": false,
        "args": "",
        "verbose": false,
        "debug": false
      }
    },
    "lint": {
      "executor": "@nxlv/python:ruff-check",
      "outputs": [],
      "options": {
        "lintFilePatterns": [
          "wealth_management_portal_graph_search_api",
          "tests"
        ]
      },
      "cache": true,
      "dependsOn": ["format"]
    },
    "lock": {
      "executor": "@nxlv/python:lock",
      "options": {
        "update": false
      }
    },
    "openapi": {
      "cache": true,
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/graph_search_api/openapi"],
      "options": {
        "commands": [
          "uv run python packages/graph_search_api/scripts/generate_open_api.py \"dist/packages/graph_search_api/openapi/openapi.json\""
        ]
      }
    },
    "remove": {
      "executor": "@nxlv/python:remove",
      "options": {}
    },
    "serve": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run fastapi dev wealth_management_portal_graph_search_api/main.py --port 8005",
        "cwd": "packages/graph_search_api"
      },
      "continuous": true
    },
    "sync": {
      "executor": "@nxlv/python:sync",
      "options": {}
    },
    "test": {
      "executor": "@nxlv/python:run-commands",
      "outputs": [
        "{workspaceRoot}/reports/{projectRoot}/unittests",
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "command": "uv run pytest tests/",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "update": {
      "executor": "@nxlv/python:update",
      "options": {}
    }
  }
}
