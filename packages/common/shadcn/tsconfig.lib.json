{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "../../../dist/packages/common/shadcn/tsc",
    "tsBuildInfoFile": "../../../dist/packages/common/shadcn/tsc/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "types": ["node"],
    "jsx": "react-jsx",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["DOM"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ]
}
